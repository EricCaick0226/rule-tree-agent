# Required.
LLM_API_KEY=

# Defaults used by the CLI when not provided as flags.
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=your-model-name
LLM_TIMEOUT=240
LLM_TEMPERATURE=0
LLM_STREAM=true
LLM_MAX_TOKENS=3000

# Claim extraction is usually the bottleneck. CLAIM_BATCH_SIZE is the max
# chunks per LLM call; CLAIM_BATCH_MAX_CHARS is the max source-text budget.
CLAIM_BATCH_SIZE=8
CLAIM_BATCH_MAX_CHARS=6000
CLAIM_CHECKPOINT_ENABLED=true
CLAIM_RESUME=true

# Block signal classification batching. Signals are non-destructive hints only.
BLOCK_BATCH_MAX_CHARS=6000
BLOCK_CHECKPOINT_ENABLED=true
BLOCK_RESUME=true

# Row extraction batching for long table-like txt/md inputs.
ROW_SEGMENT_MAX_CHARS=5000
ROW_BATCH_MAX_CHARS=7000
ROW_CHECKPOINT_ENABLED=true
ROW_RESUME=true

# Stage-level output budgets. Later synthesis stages keep more room than extraction.
LLM_CLAIM_MAX_TOKENS=2000
LLM_BLOCK_MAX_TOKENS=4000
LLM_ROW_MAX_TOKENS=6000
LLM_CONCEPT_MAX_TOKENS=1600
LLM_DIMENSION_MAX_TOKENS=1600
LLM_TAXONOMY_MAX_TOKENS=3000
LLM_DESCRIPTION_MAX_TOKENS=3000
LLM_GRADING_MAX_TOKENS=3000
LLM_RULE_MAX_TOKENS=4000

# Stage-level claim caps. Set a value <= 0 to disable the cap for a stage.
LLM_CONCEPT_MAX_CLAIMS=300
LLM_DIMENSION_MAX_CLAIMS=150
LLM_TAXONOMY_MAX_CLAIMS=350
LLM_DESCRIPTION_MAX_CLAIMS=350
LLM_GRADING_MAX_CLAIMS=350
LLM_RULE_MAX_CLAIMS=300
